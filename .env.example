# BookHub — variáveis de ambiente
# Renomeie para .env e preencha os valores

# Chave secreta do Flask (gere uma forte em produção)
SECRET_KEY=troque-por-uma-chave-muito-segura-aqui

# Google Books API Key (opcional mas recomendado)
# Obtenha em: https://console.cloud.google.com/
GOOGLE_BOOKS_API_KEY=

# URL do banco de dados
# SQLite local (padrão):
DATABASE_URL=sqlite:///bookhub.db

# PostgreSQL (Railway em produção):
# DATABASE_URL=postgresql://user:password@host:5432/bookhub
